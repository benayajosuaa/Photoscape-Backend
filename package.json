{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "postinstall": "prisma generate",
    "dev": "nodemon --watch src --ext ts --exec \"npm run build && node dist/index.js\"",
    "seed:booking": "node --import ./ts-node-register.mjs src/scripts/seed-booking.ts",
    "seed:today": "SCHEDULE_SEED_DAYS_AHEAD=1 SCHEDULE_INCLUDE_TODAY=true node --import ./ts-node-register.mjs src/scripts/seed-booking.ts",
    "seed:quick": "SCHEDULE_SEED_DAYS_AHEAD=3 SCHEDULE_INCLUDE_TODAY=true node --import ./ts-node-register.mjs src/scripts/seed-booking.ts",
    "seed:full": "SCHEDULE_SEED_DAYS_AHEAD=30 SCHEDULE_INCLUDE_TODAY=true node --import ./ts-node-register.mjs src/scripts/seed-booking.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.100.1",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.4",
    "prisma": "^5.22.0",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/validator": "^13.15.10",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
